---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import { getCollection } from 'astro:content';
import { sitePath } from '../../utils/site';

const reviews = await getCollection('reviews');
const sorted = [...reviews].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Reviews | Nibble & Noble" description="All dining reviews and critic notes from Nibble & Noble.">
  <Header />
  <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-10 sm:px-6 sm:py-14">
    <header class="mb-10 max-w-2xl">
      <h1 class="font-display text-3xl font-semibold text-nn-cream sm:text-4xl">Reviews</h1>
      <p class="mt-3 text-nn-muted leading-relaxed">
        Every entry is a single sitting—or several—distilled into what mattered on the plate and in the room.
      </p>
      <p class="mt-4 text-sm text-stone-500">
        Subscribe via <a href={sitePath('rss.xml')} class="text-nn-sage hover:text-nn-cream">RSS</a>.
      </p>
    </header>
    <p id="reviews-search-status" class="mb-6 hidden text-sm text-nn-muted"></p>
    <div id="reviews-grid" class="grid gap-6 sm:grid-cols-2">
      {sorted.map((review) => <ReviewCard review={review} />)}
    </div>
    <p id="reviews-search-empty" class="mt-8 hidden text-sm text-nn-muted">
      No reviews matched that search yet.
    </p>
  </main>
  <Footer />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const query = (params.get('q') || '').trim().toLowerCase();
  const cards = Array.from(document.querySelectorAll('[data-review-card]'));
  const searchInput = document.getElementById('site-search');
  const status = document.getElementById('reviews-search-status');
  const empty = document.getElementById('reviews-search-empty');

  if (searchInput instanceof HTMLInputElement) {
    searchInput.value = params.get('q') || '';
  }

  if (!query) {
    if (status) status.classList.add('hidden');
    if (empty) empty.classList.add('hidden');
  } else {
    let visibleCount = 0;

    cards.forEach((card) => {
      const haystack = (card.getAttribute('data-search') || '').toLowerCase();
      const match = haystack.includes(query);
      card.classList.toggle('hidden', !match);
      if (match) visibleCount += 1;
    });

    if (status) {
      status.textContent = `Search results for "${params.get('q')}"`;
      status.classList.remove('hidden');
    }

    if (empty) {
      empty.classList.toggle('hidden', visibleCount > 0);
    }
  }
</script>
