---
import type { CollectionEntry } from 'astro:content';
import RatingStars from './RatingStars.astro';
import { sitePath } from '../utils/site';

interface Props {
  review: CollectionEntry<'reviews'>;
}

const { review } = Astro.props;
const { title, description, pubDate, venue, location, rating, priceBand, cuisine, tags, heroImage } =
  review.data;
const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const href = sitePath(`reviews/${review.slug}`);
const imgSrc = heroImage ? sitePath(heroImage.replace(/^\/+/, '')) : null;
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-nn-border bg-nn-surface/50 shadow-cozy transition hover:border-nn-accent-border hover:bg-nn-surface"
>
  <a href={href} class="flex flex-1 flex-col outline-none focus-visible:ring-2 focus-visible:ring-nn-sage focus-visible:ring-offset-2 focus-visible:ring-offset-nn-bg">
    <div class="relative aspect-[16/9] w-full overflow-hidden bg-gradient-to-br from-stone-800 via-nn-surface to-nn-sage-dim/40">
      {
        imgSrc ? (
          <img src={imgSrc} alt="" class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]" loading="lazy" />
        ) : (
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-nn-sage/25 via-transparent to-transparent" aria-hidden="true" />
        )
      }
      <div class="absolute bottom-3 left-3 right-3 flex flex-wrap items-end justify-between gap-2">
        <p class="font-display text-lg text-nn-cream drop-shadow-md">{venue}</p>
        {priceBand && (
          <span class="rounded-full bg-nn-bg/70 px-2 py-0.5 text-xs font-medium text-nn-cream backdrop-blur">{priceBand}</span>
        )}
      </div>
    </div>
    <div class="flex flex-1 flex-col gap-3 p-5">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-nn-muted">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        <span aria-hidden="true">·</span>
        <span>{location}</span>
        {cuisine && (
          <>
            <span aria-hidden="true">·</span>
            <span>{cuisine}</span>
          </>
        )}
      </div>
      <h2 class="font-display text-xl font-semibold leading-snug text-nn-cream group-hover:text-nn-sage transition-colors">
        {title}
      </h2>
      <p class="line-clamp-3 text-sm leading-relaxed text-stone-300">{description}</p>
      {rating != null && <RatingStars rating={rating} />}
      {
        tags && tags.length > 0 && (
          <ul class="mt-auto flex flex-wrap gap-2 pt-1" role="list">
            {tags.slice(0, 4).map((tag) => (
              <li>
                <span class="rounded-full border border-nn-border bg-nn-bg/50 px-2 py-0.5 text-[11px] uppercase tracking-wide text-nn-muted">
                  {tag}
                </span>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </a>
</article>
