---
import { sitePath } from '../utils/site';

const pathname = Astro.url.pathname;
const homeHref = sitePath('');

function norm(p: string): string {
  const t = p.replace(/\/+$/, '');
  return t === '' ? '/' : t;
}

const link = (pathFromRoot: string, label: string) => {
  const rel = pathFromRoot.replace(/^\/+/, '');
  const href = sitePath(rel);
  const nPath = norm(pathname);
  const nHref = norm(href);
  const active = nPath === nHref || nPath.startsWith(`${nHref}/`);
  return { href, label, active };
};

const nav = [link('reviews', 'Reviews'), link('about', 'About')];
const reviewsHref = sitePath('reviews');
---

<header class="border-b border-nn-border bg-nn-bg/90 backdrop-blur-sm sticky top-0 z-20">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6">
    <a
      href={homeHref}
      class="font-display text-xl font-semibold tracking-tight text-nn-cream hover:text-nn-sage transition-colors"
    >
      Nibble & Noble
    </a>
    <nav class="flex flex-wrap items-center gap-1 sm:gap-2" aria-label="Main">
      {
        nav.map(({ href, label, active }) => (
          <a
            href={href}
            class:list={[
              'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
              active
                ? 'bg-nn-sage/20 text-nn-cream'
                : 'text-nn-muted hover:bg-nn-surface hover:text-nn-cream',
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>
    <form action={reviewsHref} method="get" class="w-full sm:w-auto sm:max-w-[240px] flex-1 sm:flex-initial">
      <label class="sr-only" for="site-search">Search reviews</label>
      <input
        id="site-search"
        name="q"
        type="search"
        placeholder="Search reviews"
        class="w-full rounded-xl border border-nn-border bg-nn-surface/60 px-3 py-2 text-sm text-nn-text placeholder:text-stone-500 transition focus:border-nn-accent-border focus:outline-none focus:ring-2 focus:ring-nn-sage/30"
      />
    </form>
  </div>
</header>
