---
import { sitePath } from '../utils/site';

interface Props {
  src: string;
  alt: string;
  caption?: string;
  tilt?: number;
  size?: number;
}

const { src, alt, caption, tilt = -2, size = 320 } = Astro.props;
const cleanSrc = sitePath(src.replace(/^\/+/, ''));
const rotation = `${tilt}deg`;
---

<figure class="nn-polaroid" style={`--nn-polaroid-rotate: ${rotation}; --nn-polaroid-size: ${size}px;`}>
  <div class="nn-polaroid__frame">
    <div class="nn-polaroid__photo">
      <img src={cleanSrc} alt={alt} loading="lazy" decoding="async" />
    </div>
    {caption && <figcaption class="nn-polaroid__caption">{caption}</figcaption>}
  </div>
</figure>

<style>
  .nn-polaroid {
    display: flex;
    justify-content: center;
    margin: 2.25rem auto;
    perspective: 600px;
  }

  .nn-polaroid__frame {
    background: linear-gradient(180deg, #fdfaf3, #f4ede0);
    padding: 0.85rem 0.85rem 2.75rem;
    border-radius: 4px;
    width: var(--nn-polaroid-size, 320px);
    max-width: 100%;
    transform: rotate(var(--nn-polaroid-rotate, -2deg));
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 14px 28px rgba(0, 0, 0, 0.45),
      0 22px 60px rgba(0, 0, 0, 0.35);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .nn-polaroid__frame:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 18px 36px rgba(0, 0, 0, 0.5),
      0 28px 80px rgba(0, 0, 0, 0.4);
  }

  .nn-polaroid__photo {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #1c1917;
    border-radius: 2px;
  }

  .nn-polaroid__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .nn-polaroid__caption {
    margin-top: 0.85rem;
    text-align: center;
    font-family: 'Caveat', 'Bradley Hand', cursive;
    font-size: 1.15rem;
    color: #3a342a;
    letter-spacing: 0.01em;
  }

  @media (prefers-reduced-motion: reduce) {
    .nn-polaroid__frame {
      transition: none;
    }
    .nn-polaroid__frame:hover {
      transform: rotate(var(--nn-polaroid-rotate, -2deg));
    }
  }
</style>
